/target
# stray local agent config (installer test artifact) — not part of the project
/opencode.jsonc
/.codegraph
/.jfc/
# research corpus (259MB, embedded vendored checkouts) — on disk, versioned in jfc
/analysis/research/
# Keep the narrow tree-sitter ABI compatibility crate versioned even when a
# user-level gitignore excludes vendor directories.
!/vendor/
/vendor/*
!/vendor/tree-sitter-compat-0-20/
!/vendor/tree-sitter-compat-0-20/**
.codex/
.omo/
.claude/
.cortexkit/

# testsprite-rs: local run state (SQLite DB + generated artifacts) is machine-local;
# the re-importable suite (testsprite_tests/mcp-suite.json) is tracked.
testsprite_tests/*
!testsprite_tests/mcp-suite.json
